# ╔══════════════════════════════════════════════════════════════╗
# ║                  TaskForge — .gitignore                      ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Environment variables ────────────────────────────────────
# Never commit real .env files
.env
.env.*
# But always keep example templates
!.env.example
!**/.env.example

# ─── Build outputs ────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
**/dist/
**/build/

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Runtime & cache ──────────────────────────────────────────
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo
.eslintcache
.stylelintcache

# ─── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor & IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ─── Testing & coverage ───────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ─── Package manager locks (keep only one) ────────────────────
# Uncomment the ones you don't use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── Misc ─────────────────────────────────────────────────────
*.local
*.orig
*.bak
*.tmp
.temp/
tmp/
